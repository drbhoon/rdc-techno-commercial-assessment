# ──────────────────────────────────────────────────────────────────────────────
# RDC Techno-Commercial Assessment — Environment Configuration
# Copy to .env.local for local dev. Railway injects these automatically.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Local dev: spin up a local Postgres or use Railway's DB URL
# Railway:   automatically injected as DATABASE_URL when you add a PG service
DATABASE_URL=postgresql://user:password@localhost:5432/rdc_assessment

# ── AI Provider ────────────────────────────────────────────────────────────────
# Supported: anthropic (default) | openai | gemini
AI_PROVIDER=anthropic

# Anthropic (get key from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: override model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI stub (set AI_PROVIDER=openai to activate) ──────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Gemini stub (set AI_PROVIDER=gemini to activate) ──────────────────────────
# GEMINI_API_KEY=AI...
